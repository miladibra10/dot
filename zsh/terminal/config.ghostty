keybind = super+right=next_tab
keybind = super+left=previous_tab

keybind = super+d=new_split:down
keybind = super+e=new_split:right

keybind = ctrl+shift+left=resize_split:left,20
keybind = ctrl+shift+right=resize_split:right,20
keybind = ctrl+shift+up=resize_split:up,20
keybind = ctrl+shift+down=resize_split:down,20

keybind = super+shift+right=goto_split:right
keybind = super+shift+left=goto_split:left
keybind = super+shift+up=goto_split:up
keybind = super+shift+down=goto_split:down